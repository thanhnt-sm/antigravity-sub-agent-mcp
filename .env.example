# Antigravity Sub-Agent MCP Server
# All variables are optional — the server auto-detects by default.

# Language Server port (auto-detected from running LS process)
# ANTIGRAVITY_PORT=53525

# CSRF token (auto-detected from LS command line args)
# ANTIGRAVITY_CSRF=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Use TLS for LS API (default: true)
# ANTIGRAVITY_TLS=true
